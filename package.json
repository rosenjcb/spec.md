{
  "name": "spec.md",
  "version": "0.3.0",
  "private": true,
  "description": "spec.md — an agent-native specification framework. This root package wires up the packaging tooling; the publishable CLI lives in ./cli.",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "sync": "node scripts/sync-adapters.mjs",
    "sync:check": "node scripts/sync-adapters.mjs --check",
    "spec-md": "node cli/bin/spec-md.js",
    "lint:specs": "node cli/bin/spec-md.js lint .",
    "check:specs": "node cli/bin/spec-md.js check .",
    "test": "node cli/test/run.js && node scripts/test/run.js",
    "test:cli": "node cli/test/run.js",
    "test:scripts": "node scripts/test/run.js",
    "changeset:version": "node scripts/changeset-version.mjs",
    "changeset:check": "node scripts/check-changeset-consistency.mjs",
    "publish:check": "node scripts/check-publish-targets.mjs",
    "release": "node scripts/publish.mjs"
  },
  "homepage": "https://github.com/rosenjcb/spec.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rosenjcb/spec.md.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.31.0"
  }
}
