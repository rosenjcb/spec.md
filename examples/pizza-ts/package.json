{
  "name": "pizza-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A spec.md reference example: a tiny pizza ordering API built from order.spec.md",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "http": "httpyac send http/*.http --all"
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "httpyac": "^6.16.6",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^2.0.5"
  }
}
